{
  "name": "sleep-catcher",
  "version": "0.1.0",
  "description": "Find the hard-coded waits that make your tests slow & flaky.",
  "keywords": [
    "testing",
    "flaky",
    "flaky-tests",
    "sleep",
    "wait",
    "playwright",
    "cypress",
    "selenium",
    "webdriverio",
    "lint",
    "cli",
    "static-analysis"
  ],
  "type": "module",
  "bin": {
    "sleep-catcher": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@babel/parser": "^7.25.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@babel/types": "^7.25.0",
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.1.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohdbilal2000/sleep-catcher.git"
  },
  "homepage": "https://github.com/mohdbilal2000/sleep-catcher#readme",
  "bugs": {
    "url": "https://github.com/mohdbilal2000/sleep-catcher/issues"
  },
  "author": "Mohd Bilal",
  "license": "MIT"
}
